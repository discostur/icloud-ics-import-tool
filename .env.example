# Copy to .env and fill in. .env is gitignored — never commit real credentials.
#
# ICLOUD_USER:         your PRIMARY Apple ID e-mail (the one you sign into iCloud with),
#                      not necessarily an @icloud.com alias.
# ICLOUD_APP_PASSWORD: an APP-SPECIFIC password from https://account.apple.com
#                      (Sign-In & Security -> App-Specific Passwords). Format
#                      xxxx-xxxx-xxxx-xxxx (keep the dashes). This is NOT your normal
#                      login password — under two-factor auth that always returns 401.
# ICLOUD_SERVER:       optional. Any RFC 4791 CalDAV base URL. Defaults to iCloud.

ICLOUD_USER=
ICLOUD_APP_PASSWORD=
# ICLOUD_SERVER=https://caldav.icloud.com/
